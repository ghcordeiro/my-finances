DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/my_finances_test?schema=public"
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Autenticação
COOKIE_SECRET="troque-em-producao"

# CORS (SPA): em dev a API também libera localhost/127.0.0.1 nas portas 5173–5176 e 4173.
# Em produção, liste todas as origens reais, separadas por vírgula.
WEB_ORIGIN="http://127.0.0.1:5173,http://localhost:5173"

# Dev: alvo do proxy do Vite (SPA chama /v1/* no mesmo host que o Vite)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000

# Billing
BILLING_PROVIDER=none

# Stripe (webhooks)
STRIPE_WEBHOOK_SECRET=

# S3 / MinIO (opcional)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Rate limit auth (testes podem reduzir)
RATE_LIMIT_AUTH_MAX=120
RATE_LIMIT_AUTH_WINDOW_MS=60000
