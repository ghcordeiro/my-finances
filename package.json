{
  "name": "my-finances",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "pnpm --filter @my-finances/api dev",
    "dev:web": "pnpm --filter @my-finances/web dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @my-finances/api test",
    "test:e2e": "pnpm --filter @my-finances/web test:e2e",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate",
    "lint": "pnpm --filter @my-finances/api lint"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
